{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.deepdevy/museum",
  "description": "MCP server for Harvard Art Museums API",
  "repository": {
    "url": "https://github.com/deepdevy/mcp-market",
    "source": "github"
  },
  "version": "0.1.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@mcp-market/museum",
      "version": "0.1.0",
      "transport": {
        "type": "stdio"
      }
    }
  ],
  "environmentVariables": [
    {
      "name": "HARVARD_ART_API_KEY",
      "description": "Harvard Art Museums API key",
      "isRequired": true,
      "isSecret": true
    }
  ]
}
